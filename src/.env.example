# Object storage
# local = store artifacts under LOCAL_ARTIFACT_ROOT without AWS (dev)
# s3 = use S3/S3-compatible object storage (production)
OBJECT_STORAGE_MODE=local
LOCAL_ARTIFACT_ROOT=
LOCAL_ARTIFACT_BASE_URL=http://localhost:8000

# AWS Credentials (only required when OBJECT_STORAGE_MODE=s3 and no IAM role is available)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# S3 Output Configuration (required when OBJECT_STORAGE_MODE=s3)
S3_OUTPUT_BUCKET=

# API keys for different providers
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
CARTESIA_API_KEY=
SMALLEST_API_KEY=
GROQ_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT_ID=
SARVAM_API_KEY=
ELEVENLABS_API_KEY=
OPENROUTER_API_KEY=
# comma-separated list of OpenRouter provider slugs to expose via GET /openrouter/providers
# leave empty to return all providers
OPENROUTER_ALLOWED_PROVIDERS=

# Provider status monitor. GET /provider-status returns the cached result
# immediately; a background task refreshes it by running `calibrate status`.
PROVIDER_STATUS_REFRESH_INTERVAL_SECONDS=300
PROVIDER_STATUS_CACHE_MAX_AGE_SECONDS=900
PROVIDER_STATUS_CHECK_TIMEOUT_SECONDS=120

DB_ROOT_DIR=

# API Docs Authentication (HTTP Basic Auth for /docs, /redoc, /openapi.json)
DOCS_USERNAME=admin
DOCS_PASSWORD=changeme

# OpenAPI `servers` URL in GET /public-api/openapi.json (default localhost).
PUBLIC_API_BASE_URL=http://localhost:8000

GOOGLE_CLIENT_ID=

# update this with the url of your app
CORS_ALLOWED_ORIGINS=http://localhost:3000

# REQUIRED - Change this in production! generate using openssl rand -base64 32
JWT_SECRET_KEY=your-secret-key-at-least-32-characters-long

# OPTIONAL - Default: 168 (7 days)
JWT_EXPIRATION_HOURS=168

# number of jobs to run concurrently while others are queued
MAX_CONCURRENT_JOBS=1
# Per-org cap on concurrent jobs (renamed from MAX_CONCURRENT_JOBS_PER_USER
# during the multi-tenant migration — the old name is still read for
# backward compat with a deprecation warning).
MAX_CONCURRENT_JOBS_PER_ORG=1

# default max rows allowed per eval run (used when no org-specific limit is set)
DEFAULT_MAX_ROWS_PER_EVAL=20

# Calibrate CLI row-level parallelism, read natively by the CLI (leave unset
# to use the CLI's own defaults)
CALIBRATE_TEST_PARALLEL=4          # test cases per `calibrate llm` model run
CALIBRATE_SIMULATION_PARALLEL=2    # simulations run in parallel by `calibrate simulations`

# superadmin email — required for mutating user-limits endpoints (POST/PUT/DELETE)
SUPERADMIN_EMAIL=

# Sentry - leave SENTRY_DSN empty to disable
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0

ENVIRONMENT=development # langfuse tracing environment
ENABLE_TRACING=false

# OTLP endpoint (defaults to localhost:4317 if not set)
# OTEL_EXPORTER_OTLP_ENDPOINT="https://cloud.langfuse.com/api/public/otel" # 🇪🇺 EU data region
# OTEL_EXPORTER_OTLP_ENDPOINT="https://us.cloud.langfuse.com/api/public/otel" # 🇺🇸 US data region
OTEL_EXPORTER_OTLP_ENDPOINT="{LANGFUSE HOST}/api/public/otel" # for self-hosted Langfuse
# Base64 encode your Langfuse public and secret key:
# echo -n "pk-lf-1234567890:sk-lf-1234567890" | base64
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20<base64_encoded_api_key>

LANGFUSE_TRACING_ENVIRONMENT=
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

DEFAULT_USER_EMAIL=
DEFAULT_USER_FIRST_NAME=
DEFAULT_USER_LAST_NAME=

# Default config applied to agents created via POST /agents (type=agent).
# Caller-supplied config is deep-merged on top, so partial overrides work.
# All optional — leave empty to use the hardcoded fallbacks in src/routers/agents.py.
DEFAULT_AGENT_SYSTEM_PROMPT=You are a helpful assistant.
DEFAULT_AGENT_LLM_MODEL=google/gemini-2.5-flash
DEFAULT_AGENT_STT_PROVIDER=google
DEFAULT_AGENT_TTS_PROVIDER=google
DEFAULT_AGENT_SPEAKS_FIRST=false
DEFAULT_AGENT_MAX_TURNS=10

# Default persona attributes used by the simulation builder when a
# persona's own config doesn't specify them. Hardcoded fallbacks live
# in src/routers/simulations.py.
DEFAULT_PERSONA_GENDER=female
DEFAULT_PERSONA_LANGUAGE=english
DEFAULT_PERSONA_INTERRUPTION_SENSITIVITY=medium
